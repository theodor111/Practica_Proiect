/**
 * Utility Components
 * ErrorBoundary - Error handling boundary for React
 * SessionExpiredModal - Session expiration notification
 * TypingIndicator - Animated typing indicator
 * ChatMessage - Individual message bubble component
 */

// React hooks accessed via React.useState, React.useEffect, etc.

// Error Boundary Component - prevents blank pages on crashes
class ErrorBoundary extends React.Component {
  constructor(props) {
    super(props);
    this.state = { hasError: false, error: null, errorInfo: null };
  }

  static getDerivedStateFromError(error) {
    return { hasError: true, error };
  }

  componentDidCatch(error, errorInfo) {
    console.error('Error caught by boundary:', error, errorInfo);
    this.setState({ errorInfo });
    // Send to error tracking if available
    if (window.Sentry) {
      window.Sentry.captureException(error, { extra: errorInfo });
    }
  }

  render() {
    if (this.state.hasError) {
      return React.createElement('div', {
        className: 'error-boundary-container'
      },
        React.createElement('h1', { className: 'error-boundary-title' }, 'Something went wrong'),
        React.createElement('p', { className: 'error-boundary-message' },
          'The application encountered an error. Please refresh the page to continue.'
        ),
        React.createElement('button', {
          onClick: () => window.location.reload(),
          className: 'error-boundary-btn'
        }, 'Refresh Page'),
        this.state.error && React.createElement('div', {
          className: 'error-boundary-details'
        },
          React.createElement('strong', null, 'Error Details:'),
          React.createElement('pre', null,
            this.state.error.toString()
          )
        )
      );
    }

    return this.props.children;
  }
}

// Session Expired Modal Component
const SessionExpiredModal = ({ onRelogin }) => {
  return React.createElement('div', {
    className: 'session-expired-overlay'
  },
    React.createElement('div', {
      className: 'session-expired-modal'
    },
      React.createElement('h2', {
        className: 'session-expired-title'
      }, 'Session Expired'),
      React.createElement('p', {
        className: 'session-expired-message'
      }, 'Your session has timed out due to inactivity.'),
      React.createElement('button', {
        onClick: onRelogin,
        className: 'session-expired-btn'
      }, 'Sign In')
    )
  );
};

// Jurisdiction display names and ordering (broadest to narrowest)
const JURISDICTION_NAMES = {
  INTL: 'International',
  EU: 'European Union',
  DK: 'Denmark'
};

const JURISDICTION_ORDER = ['INTL', 'EU', 'DK'];

const formatJurisdictions = (codes) => {
  if (!codes || codes.length === 0) return '';
  return JURISDICTION_ORDER
    .filter(code => codes.includes(code))
    .map(code => JURISDICTION_NAMES[code])
    .join(', ');
};

// Typing Indicator Component with jurisdiction text
// statusText: Dynamic status message from the backend (e.g., "Analysing your question...", "Searching EU law...")
// isExtendedOverride: Fallback for legacy extended_search event
const TypingIndicator = ({ jurisdictions, hasStreamStarted, isExtendedOverride, statusText }) => {
  const jurisdictionText = formatJurisdictions(jurisdictions);

  // Determine display text: prefer dynamic statusText from backend, fall back to hardcoded
  let displayText = statusText;
  if (!displayText && jurisdictionText) {
    const prefix = isExtendedOverride ? 'Extended research' : 'Researching';
    displayText = `${prefix} ${jurisdictionText}`;
  }

  const logoElement = React.createElement('img', {
    src: '/favicon.svg',
    alt: 'eulaw.ai',
    className: 'typing-indicator-logo'
  });

  // Always show indicator while streaming — logo + contextual text
  return React.createElement('div', {
    className: 'typing-indicator typing-indicator-container'
  },
    logoElement,
    React.createElement('span', {
      className: 'typing-indicator-text'
    }, hasStreamStarted ? (displayText || 'Generating response...') : (displayText || 'Connecting...'))
  );
};

// Utility functions are loaded from utils/markdown.js and utils/export.js
// They are available on the window object:
// - window.escapeHtml (from utils/markdown.js)
// - window.exportToWord (from utils/export.js)
// - window.parseInlineFormattingForDocx (from utils/export.js)
// - window.enhanceExistingCitationMarkers (from utils/markdown.js)
// - window.parseMarkdown (from utils/markdown.js)

// Convert HTML to formatted plain text while preserving structure
const formatHtmlToText = (element) => {
  let result = '';

  for (let node of element.childNodes) {
    if (node.nodeType === Node.TEXT_NODE) {
      result += node.textContent;
    } else if (node.nodeType === Node.ELEMENT_NODE) {
      const tagName = node.tagName.toLowerCase();

      // Add appropriate formatting based on HTML tags
      switch (tagName) {
        case 'h1':
        case 'h2':
        case 'h3':
        case 'h4':
        case 'h5':
        case 'h6':
          result += '\n\n' + formatHtmlToText(node) + '\n';
          break;
        case 'p':
          result += '\n' + formatHtmlToText(node);
          break;
        case 'br':
          result += '\n';
          break;
        case 'li':
          result += '\n• ' + formatHtmlToText(node);
          break;
        case 'ul':
        case 'ol':
          result += '\n' + formatHtmlToText(node);
          break;
        case 'blockquote':
          result += '\n\n' + formatHtmlToText(node);
          break;
        case 'strong':
        case 'b':
          result += formatHtmlToText(node);
          break;
        case 'em':
        case 'i':
          result += formatHtmlToText(node);
          break;
        case 'code':
          result += formatHtmlToText(node);
          break;
        case 'pre':
          result += '\n\n' + formatHtmlToText(node) + '\n';
          break;
        default:
          result += formatHtmlToText(node);
      }
    }
  }

  return result;
};

// Chat Message Component (memoized to prevent unnecessary re-renders)
/**
 * Close unclosed markdown tokens so the parser can render partial streaming text.
 * Only used during streaming — avoids raw ** / ` / [ leaking into the rendered output.
 */
function closeStreamingMarkdown(text) {
  // Count unmatched ** (bold) — if odd number of **, append one to close
  const boldMatches = text.match(/\*\*/g);
  if (boldMatches && boldMatches.length % 2 !== 0) text += '**';
  // Count unmatched * (italic, not part of **) — simplified: check trailing *
  else if (/(?<!\*)\*[^*]+$/.test(text)) text += '*';
  // Unclosed inline code
  const backtickMatches = text.match(/`/g);
  if (backtickMatches && backtickMatches.length % 2 !== 0) text += '`';
  // Unclosed link: [text]( without closing )
  if (/\[[^\]]*\]\([^)]*$/.test(text)) text += ')';
  // Unclosed link text: [text without ]
  else if (/\[[^\]]*$/.test(text)) text += ']()';
  return text;
}

const ChatMessage = React.memo(({ message, isUser, timestamp, citations, inlineCitations, artifacts, files, isStreaming, userQuestion, responseNumber, onSaveToLibrary, followUpQuestions, onFollowUpClick, onOpenSourcesPanel }) => {
  const [isCopied, setIsCopied] = React.useState(false);
  const [isExporting, setIsExporting] = React.useState(false);
  const [isSaving, setIsSaving] = React.useState(false);
  const [isSaved, setIsSaved] = React.useState(false);

  const handleExportToWord = async () => {
    if (isExporting) return;
    setIsExporting(true);
    try {
      if (window.exportToWord) {
        await window.exportToWord(message, citations || [], userQuestion || '');
      } else {
        console.error('exportToWord utility not loaded');
      }
    } finally {
      setIsExporting(false);
    }
  };

  const handleSaveToLibrary = async () => {
    if (isSaving || isSaved || !onSaveToLibrary) return;
    setIsSaving(true);
    try {
      const success = await onSaveToLibrary(message, citations || [], userQuestion || '', responseNumber);
      if (success) {
        setIsSaved(true);
        // Reset after 3 seconds
        setTimeout(() => setIsSaved(false), 3000);
      }
    } catch (error) {
      console.error('Failed to save to library:', error);
    } finally {
      setIsSaving(false);
    }
  };

  // Use window.formatTime from utils/export.js if available
  const formatTime = window.formatTime || ((timestamp) => {
    if (!timestamp) return '';
    const date = new Date(timestamp);
    const day = String(date.getDate()).padStart(2, '0');
    const month = String(date.getMonth() + 1).padStart(2, '0');
    const year = date.getFullYear();
    const hours = String(date.getHours()).padStart(2, '0');
    const minutes = String(date.getMinutes()).padStart(2, '0');
    return `${day}.${month}.${year} - ${hours}:${minutes}`;
  });

  const copyToClipboard = async () => {
    try {
      // Convert markdown to HTML using the same function as display
      const htmlContent = window.parseMarkdown ? window.parseMarkdown(message) : message;

      // Create a temporary DOM element to get formatted text (XSS-safe)
      const parser = new DOMParser();
      const doc = parser.parseFromString(htmlContent, 'text/html');
      const tempDiv = doc.body;

      // Collapse runs of 3+ newlines into a single blank line
      const formattedText = formatHtmlToText(tempDiv).replace(/\n{3,}/g, '\n\n').trim();

      await navigator.clipboard.writeText(formattedText);
      // Show checkmark feedback
      setIsCopied(true);
      setTimeout(() => setIsCopied(false), 1500); // Hide after 1.5 seconds
    } catch (err) {
      // Fallback for older browsers (XSS-safe)
      const htmlContent = window.parseMarkdown ? window.parseMarkdown(message) : message;
      const parser = new DOMParser();
      const doc = parser.parseFromString(htmlContent, 'text/html');
      const tempDiv = doc.body;

      const formattedText = formatHtmlToText(tempDiv).replace(/\n{3,}/g, '\n\n').trim();

      const textArea = document.createElement('textarea');
      textArea.value = formattedText;
      document.body.appendChild(textArea);
      textArea.select();
      document.execCommand('copy');
      document.body.removeChild(textArea);
      // Show checkmark feedback for fallback too
      setIsCopied(true);
      setTimeout(() => setIsCopied(false), 1500);
    }
  };

  return React.createElement('div', {
    className: isUser ? 'user-message-wrapper' : 'ai-message-wrapper',
    'data-response-number': !isUser && responseNumber ? responseNumber : undefined
  },
    React.createElement('div', {
      className: isUser ? 'user-message message-bubble' : `ai-message message-bubble${isStreaming ? ' streaming' : ''}`
    },
      // Show file attachments if present (for user messages) - positioned at TOP
      isUser && files && files.length > 0 && React.createElement('div', {
        className: `file-attachments${message ? ' has-message' : ''}`
      },
        files.map((file, index) => React.createElement('div', {
          key: index,
          className: 'file-attachment'
        },
          React.createElement('i', {
            className: 'fas fa-paperclip file-attachment-icon'
          }),
          React.createElement('span', {
            className: 'file-attachment-name'
          }, `${file.name} (${(file.size / 1024 / 1024).toFixed(1)}MB)`)
        ))
      ),
      // Render AI messages with Markdown, user messages as plain text (only if there's message content)
      message && (isUser
        ? React.createElement('div', {
            className: 'whitespace-pre-wrap break-words'
          }, message)
        : React.createElement('div', {
            className: 'break-words',
            // Use mousedown instead of click - click requires mouseup on same element,
            // but during streaming the DOM may be replaced between mousedown and mouseup
            onMouseDown: (e) => {
              // Only handle left clicks
              if (e.button !== 0) return;
              const link = e.target.closest('a[href]');
              if (link) {
                e.preventDefault();
                window.open(link.href, '_blank', 'noopener,noreferrer');
              }
            },
            dangerouslySetInnerHTML: { __html: window.parseMarkdown ? window.parseMarkdown(isStreaming ? closeStreamingMarkdown(message) : message, citations) : message }
          })),
      // Add bottom row with copy button and timestamp for all messages
      React.createElement('div', {
        className: `message-bottom-row ${isUser ? 'user' : 'ai'}`
      },
        // Timestamp (separate from favicons)
        timestamp && React.createElement('span', null, formatTime(timestamp)),
        // Only show copy button when not streaming
        !isStreaming && React.createElement('button', {
          className: 'copy-message-button',
          onClick: copyToClipboard,
          title: isCopied ? 'Copied!' : 'Copy message',
        }, React.createElement('i', {
          className: `${isCopied ? 'fas fa-check' : 'fas fa-copy'} icon-transition`
        })),
        // Export to Word button (only for AI messages when not streaming)
        !isUser && !isStreaming && React.createElement('button', {
          className: 'export-word-button',
          onClick: handleExportToWord,
          title: isExporting ? 'Exporting...' : 'Export to Word',
          disabled: isExporting
        }, React.createElement('i', {
          className: `${isExporting ? 'fas fa-spinner fa-spin' : 'fas fa-file-word'} icon-transition`
        })),
        // Save to Documents button (only for AI messages when not streaming)
        !isUser && !isStreaming && onSaveToLibrary && React.createElement('button', {
          className: 'save-to-library-button',
          onClick: handleSaveToLibrary,
          title: isSaved ? 'Saved!' : (isSaving ? 'Saving...' : 'Save to Documents'),
          disabled: isSaving || isSaved
        }, React.createElement('i', {
          className: `${isSaved ? 'fas fa-check' : (isSaving ? 'fas fa-spinner fa-spin' : 'fas fa-folder-plus')} icon-transition`
        })),
        // Favicons for AI messages with citations — click opens sources panel
        !isUser && !isStreaming && citations && citations.length > 0 && (() => {
          const MAX_VISIBLE_ICONS = 8;
          const sourceCitations = citations.filter(c => c.source_url);
          const visibleCitations = sourceCitations.slice(0, MAX_VISIBLE_ICONS);
          return React.createElement('div', {
          className: 'source-indicator',
          title: 'Open Sources & Citations',
          onClick: () => onOpenSourcesPanel && onOpenSourcesPanel(responseNumber, 0)
        },
          React.createElement('div', {
            className: 'favicon-stack',
            style: {
              width: `${18 + Math.max(0, visibleCitations.length - 1) * 20}px`
            }
          },
          visibleCitations
            .map((citation, idx) => {
              try {
                const domain = window.getFaviconDomain(new URL(citation.source_url).hostname);
                const title = citation.title || citation.journal_number || citation.filename || 'Source';
                return React.createElement('div', {
                  key: `citation-${idx}`,
                  className: 'favicon-link',
                  onClick: (e) => {
                    e.stopPropagation();
                    onOpenSourcesPanel && onOpenSourcesPanel(responseNumber, idx);
                  },
                  title: title,
                  style: {
                    transform: `translateX(${idx * 20}px)`,
                    zIndex: idx
                  }
                },
                  React.createElement('img', {
                    src: `https://www.google.com/s2/favicons?domain=${domain}&sz=64`,
                    alt: title,
                    className: 'favicon-img',
                    onError: (e) => {
                      // Fallback to DuckDuckGo favicon service
                      if (!e.target.dataset.fallbackTried) {
                        e.target.dataset.fallbackTried = 'true';
                        e.target.src = `https://icons.duckduckgo.com/ip3/${domain}.ico`;
                      } else {
                        e.target.style.display = 'none';
                      }
                    }
                  })
                );
              } catch (e) {
                return null;
              }
            })
          ),
          React.createElement('span', {
            className: 'source-indicator-label'
          },
            `${sourceCitations.length} sources`
          )
        );
        })()
      ),
      // Generated document artifact pills — click opens sources panel with artifact expanded
      !isUser && !isStreaming && Array.isArray(artifacts) && artifacts.length > 0 &&
        React.createElement('div', {
          className: 'artifact-pills'
        },
          artifacts.map((artifact, idx) => {
            const icons = {
              memo: 'fa-file-alt',
              summary: 'fa-list-alt',
              comparison: 'fa-balance-scale',
              analysis: 'fa-chart-bar',
              report: 'fa-file-signature',
              contract: 'fa-file-contract',
              other: 'fa-file'
            };
            const iconClass = icons[artifact.documentType] || 'fa-file';
            return React.createElement('button', {
              key: `artifact-${artifact.artifactId || idx}`,
              className: 'artifact-pill',
              onClick: () => onOpenSourcesPanel && onOpenSourcesPanel(responseNumber, 0, artifact.artifactId),
              title: `Open ${artifact.title}`
            },
              React.createElement('i', { className: `fas ${iconClass} artifact-pill-icon` }),
              React.createElement('span', { className: 'artifact-pill-title' }, artifact.title),
              React.createElement('i', { className: 'fas fa-arrow-right artifact-pill-arrow' })
            );
          })
        ),
      // Follow-up question chips (only for AI messages, not streaming)
      !isUser && !isStreaming && followUpQuestions && followUpQuestions.length > 0 &&
        React.createElement('div', {
          className: 'follow-up-questions'
        },
          followUpQuestions.map((question, idx) =>
            React.createElement('button', {
              key: `followup-${idx}`,
              className: 'follow-up-chip',
              onClick: () => onFollowUpClick && onFollowUpClick(question)
            }, question)
          )
        )
    )
  );
});

// Export to window
window.ErrorBoundary = ErrorBoundary;
window.SessionExpiredModal = SessionExpiredModal;
window.TypingIndicator = TypingIndicator;
window.ChatMessage = ChatMessage;