/**
 * Authentication Service
 * Handles AWS Cognito authentication, token management, and session monitoring
 */

// Get React from window (loaded via CDN)
const { createContext, useContext, useState, useEffect } = React;

// ============ UTILITY FUNCTIONS ============

/**
 * Safely parse a JWT token payload
 * @param {string} token - JWT token string
 * @returns {object|null} Parsed payload or null if malformed
 */
function parseJwtPayload(token) {
  try {
    const parts = token.split('.');
    if (parts.length !== 3) return null;
    return JSON.parse(atob(parts[1]));
  } catch {
    return null;
  }
}

/**
 * Fetch with timeout protection
 * @param {string} url - URL to fetch
 * @param {object} options - Fetch options
 * @param {number} timeoutMs - Timeout in milliseconds (default: 30000)
 * @returns {Promise<Response>}
 */
async function fetchWithTimeout(url, options = {}, timeoutMs = 30000) {
  const controller = new AbortController();
  const timeoutId = setTimeout(() => controller.abort(), timeoutMs);

  // If caller provided an external signal, abort our controller when it fires
  const externalSignal = options.signal;
  if (externalSignal) {
    if (externalSignal.aborted) {
      controller.abort();
    } else {
      externalSignal.addEventListener('abort', () => controller.abort(), { once: true });
    }
  }

  try {
    const response = await fetch(url, {
      ...options,
      signal: controller.signal
    });
    return response;
  } catch (error) {
    if (error.name === 'AbortError') {
      // Distinguish user cancellation from timeout
      if (externalSignal?.aborted) {
        throw error; // Preserve AbortError for caller to detect
      }
      throw new Error(`Request timeout after ${timeoutMs}ms`);
    }
    throw error;
  } finally {
    clearTimeout(timeoutId);
  }
}

/**
 * Helper function for delayed waits with timeout
 * @param {Function} conditionFn - Function that returns true when condition is met
 * @param {number} maxWaitMs - Maximum wait time in milliseconds
 * @param {number} checkIntervalMs - Check interval in milliseconds
 * @returns {Promise<void>}
 */
function delayedWait(conditionFn, maxWaitMs = 5000, checkIntervalMs = 100) {
  return new Promise((resolve, reject) => {
    const startTime = Date.now();

    function checkCondition() {
      if (conditionFn()) {
        resolve();
        return;
      }

      if (Date.now() - startTime > maxWaitMs) {
        reject(new Error(`Timeout waiting for condition after ${maxWaitMs}ms`));
        return;
      }

      setTimeout(checkCondition, checkIntervalMs);
    }

    checkCondition();
  });
}

// ============ SECURE TOKEN STORAGE ============

/**
 * Secure token storage using sessionStorage
 * SessionStorage is cleared when tab closes, reducing exposure time
 */
const SecureTokenStorage = {
  setToken: (key, value) => {
    if (!value) return;
    sessionStorage.setItem(`secure_${key}`, value);
  },

  getToken: (key) => {
    return sessionStorage.getItem(`secure_${key}`);
  },

  removeToken: (key) => {
    sessionStorage.removeItem(`secure_${key}`);
  },

  clearAllTokens: () => {
    // Clear both new secure tokens and legacy localStorage tokens
    sessionStorage.removeItem('secure_accessToken');
    sessionStorage.removeItem('secure_idToken');
    sessionStorage.removeItem('secure_refreshToken');
    sessionStorage.removeItem('secure_userId');
    // Clear legacy localStorage for compatibility
    localStorage.removeItem('accessToken');
    localStorage.removeItem('idToken');
    localStorage.removeItem('refreshToken');
    localStorage.removeItem('userId');
  }
};

// ============ SESSION MONITORING ============

/**
 * Session expiration event emitter for app-wide monitoring
 */
class SessionExpiredEvent extends Event {
  constructor() {
    super('sessionExpired');
  }
}

// Global session monitor
let sessionMonitorInterval = null;

/**
 * Start monitoring session expiration
 * @param {AuthService} authService - Auth service instance
 */
function startSessionMonitor(authService) {
  if (sessionMonitorInterval) clearInterval(sessionMonitorInterval);

  sessionMonitorInterval = setInterval(async () => {
    try {
      const idToken = SecureTokenStorage.getToken('idToken');
      if (!idToken) return;

      const payload = parseJwtPayload(idToken);
      if (!payload) return;
      const expiresAt = payload.exp * 1000;
      const now = Date.now();
      const timeUntilExpiry = expiresAt - now;

      // Notify when less than 5 minutes left
      if (timeUntilExpiry > 0 && timeUntilExpiry < 5 * 60 * 1000) {
        console.warn('Session expiring soon, attempting refresh...');
        await authService.attemptTokenRefresh();
      } else if (timeUntilExpiry <= 0) {
        console.warn('Session expired, notifying user...');
        window.dispatchEvent(new SessionExpiredEvent());
      }
    } catch (error) {
      console.error('Error in session monitor:', error);
    }
  }, 60000); // Check every minute
}

/**
 * Stop session monitoring
 */
function stopSessionMonitor() {
  if (sessionMonitorInterval) {
    clearInterval(sessionMonitorInterval);
    sessionMonitorInterval = null;
  }
}

// ============ AUTH SERVICE ============

/**
 * Authentication Service Class
 * Handles Cognito OAuth flow, token management, and session validation
 */
class AuthService {
  /**
   * Check if user is authenticated
   * @returns {boolean}
   */
  isAuthenticated() {
    const accessToken = SecureTokenStorage.getToken('accessToken');
    const idToken = SecureTokenStorage.getToken('idToken');

    console.log('isAuthenticated check:', {
      hasAccessToken: !!accessToken,
      hasIdToken: !!idToken,
      origin: window.location.origin
    });

    if (!accessToken || !idToken) return false;

    try {
      const payload = parseJwtPayload(idToken);
      if (!payload) return false;
      const currentTime = Math.floor(Date.now() / 1000);
      const isValid = payload.exp > currentTime;

      console.log('Token validation:', {
        exp: payload.exp,
        currentTime,
        isValid,
        email: payload.email
      });

      return isValid;
    } catch (error) {
      console.log('Token parsing error:', error);
      return false;
    }
  }

  /**
   * Get user information from ID token
   * @returns {object|null} User info { userId, email, name }
   */
  getUserInfo() {
    const idToken = SecureTokenStorage.getToken('idToken');
    if (!idToken) return null;

    const payload = parseJwtPayload(idToken);
    if (!payload) return null;
    return {
      userId: payload.sub,
      email: payload.email,
      name: payload.name || payload.email
    };
  }

  /**
   * Redirect to Cognito login page
   */
  login() {
    const params = new URLSearchParams({
      response_type: 'code',
      client_id: window.config.auth.clientId,
      redirect_uri: window.config.auth.redirectUri,
      scope: window.config.auth.scope
    });
    window.location.href = window.config.auth.cognitoDomain + 'oauth2/authorize?' + params.toString();
  }

  /**
   * Attempt to refresh access token using refresh token
   * @returns {Promise<boolean>} True if refresh successful
   */
  async attemptTokenRefresh() {
    const refreshToken = SecureTokenStorage.getToken('refreshToken');
    if (!refreshToken) {
      console.log('No refresh token available');
      return false;
    }

    try {
      console.log('Attempting to refresh token...');
      const response = await fetchWithTimeout(window.config.auth.cognitoDomain + 'oauth2/token', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams({
          grant_type: 'refresh_token',
          client_id: window.config.auth.clientId,
          refresh_token: refreshToken
        })
      }, 10000); // 10 second timeout for token refresh

      if (!response.ok) {
        console.error('Token refresh failed:', response.status);
        // If refresh fails, treat as session expired
        window.dispatchEvent(new SessionExpiredEvent());
        return false;
      }

      const tokens = await response.json();
      SecureTokenStorage.setToken('accessToken', tokens.access_token);
      SecureTokenStorage.setToken('idToken', tokens.id_token);
      if (tokens.refresh_token) SecureTokenStorage.setToken('refreshToken', tokens.refresh_token);

      console.log('Token refreshed successfully');
      return true;
    } catch (error) {
      console.error('Token refresh error:', error);
      window.dispatchEvent(new SessionExpiredEvent());
      return false;
    }
  }

  /**
   * Logout user and clear all tokens
   */
  async logout() {
    console.log('Starting comprehensive logout process...');

    // Clear session monitor first
    stopSessionMonitor();

    // Step 1: Try to revoke tokens via API if we have them
    const refreshToken = SecureTokenStorage.getToken('refreshToken');

    if (refreshToken) {
      try {
        console.log('Attempting to revoke refresh token...');
        await fetchWithTimeout(window.config.auth.cognitoDomain + 'oauth2/revoke', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
          },
          body: new URLSearchParams({
            token: refreshToken,
            client_id: window.config.auth.clientId,
            token_type_hint: 'refresh_token'
          }),
        }, 5000).catch(error => {
          console.log('Token revocation failed (expected):', error.message);
        });
      } catch (error) {
        console.log('Token revocation attempt failed:', error.message);
      }
    }

    // Step 2: Clear all secure token storage
    SecureTokenStorage.clearAllTokens();
    sessionStorage.clear();

    // Step 3: Clear any cookies that might contain auth state
    document.cookie.split(";").forEach(function(c) {
      document.cookie = c.replace(/^ +/, "").replace(/=.*/, "=;expires=" + new Date().toUTCString() + ";path=/");
    });

    // Step 4: Redirect to Cognito logout with proper logout_uri configured
    const logoutUrl = window.config.auth.cognitoDomain + 'logout?' + new URLSearchParams({
      client_id: window.config.auth.clientId,
      logout_uri: window.location.origin + '/'
    });

    console.log('Redirecting to Cognito logout:', logoutUrl);

    // Full redirect to Cognito logout - this should handle the session invalidation and redirect back
    window.location.href = logoutUrl;
  }

  /**
   * Handle OAuth callback from Cognito
   * @returns {Promise<boolean>} True if callback handled successfully
   */
  async handleCallback() {
    const urlParams = new URLSearchParams(window.location.search);
    const code = urlParams.get('code');
    const error = urlParams.get('error');
    const errorDescription = urlParams.get('error_description');

    console.log('HandleCallback called:', {
      code: code ? 'present' : 'missing',
      error: error ? 'present' : 'missing',
      errorDescription: errorDescription ? 'present' : 'missing',
      currentUrl: window.location.href,
      configRedirectUri: window.config?.auth?.redirectUri,
      currentOrigin: window.location.origin
    });

    // CASE 1: Error from Cognito (Lambda trigger error or OAuth error)
    if (error) {
      console.error('Authentication error received:', { error, errorDescription });

      // Decode the error description
      const decodedDescription = errorDescription ? decodeURIComponent(errorDescription) : '';
      console.log('Decoded error description:', decodedDescription);

      // Map error codes to user-friendly messages
      let userMessage;
      if (decodedDescription.includes('MSG:AUTH001')) {
        userMessage = 'A temporary problem caused account creation to fail. Please try again later.';
      } else if (decodedDescription.includes('MSG:AUTH002')) {
        userMessage = 'The email address is already in use. Please try a different sign-in method.';
      } else {
        userMessage = 'An unexpected temporary problem caused account creation to fail. Please try again later.';
      }

      // Clear any existing tokens
      SecureTokenStorage.clearAllTokens();

      // Clean the URL
      window.history.replaceState({}, document.title, window.location.pathname);

      // Show error message to user
      alert(userMessage);

      // Redirect to login page (Cognito authorization URL)
      const loginParams = new URLSearchParams({
        response_type: 'code',
        client_id: window.config.auth.clientId,
        redirect_uri: window.config.auth.redirectUri,
        scope: window.config.auth.scope
      });
      window.location.href = window.config.auth.cognitoDomain + 'oauth2/authorize?' + loginParams.toString();

      // Return a Promise that never resolves to prevent any further code execution
      return new Promise(() => {});
    }

    // CASE 2: No code present (normal page load without auth callback)
    if (!code) return false;

    // CASE 3: Successful authentication with authorization code
    try {
       console.log('Exchanging code for tokens with redirect_uri:', window.config.auth.redirectUri);

       const tokenResponse = await fetchWithTimeout(window.config.auth.cognitoDomain + 'oauth2/token', {
         method: 'POST',
         headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
         body: new URLSearchParams({
           grant_type: 'authorization_code',
           client_id: window.config.auth.clientId,
           code: code,
           redirect_uri: window.config.auth.redirectUri,
         }),
       }, 15000); // 15 second timeout for token exchange

      if (!tokenResponse.ok) {
        const errorText = await tokenResponse.text();
        console.error('Token exchange failed:', errorText);
        throw new Error('Token exchange failed: ' + errorText);
      }

      const tokens = await tokenResponse.json();
      console.log('Tokens received successfully');

      SecureTokenStorage.setToken('accessToken', tokens.access_token);
      SecureTokenStorage.setToken('idToken', tokens.id_token);
      if (tokens.refresh_token) SecureTokenStorage.setToken('refreshToken', tokens.refresh_token);

      // Extract userId and email from ID token
      const idTokenPayload = parseJwtPayload(tokens.id_token);
      if (idTokenPayload) {
        if (idTokenPayload.sub) {
          localStorage.setItem('userId', idTokenPayload.sub);
          console.log('UserId extracted and stored:', idTokenPayload.sub);
        }
        if (idTokenPayload.email) {
          localStorage.setItem('userEmail', idTokenPayload.email);
          console.log('User email extracted and stored:', idTokenPayload.email);
        }
      }

      window.history.replaceState({}, document.title, window.location.pathname);
      return true;
    } catch (error) {
      console.error('Auth error:', error);
      throw error;
    }
  }
}

// Create singleton instance
const authService = new AuthService();

// ============ AUTH CONTEXT & PROVIDER ============

/**
 * Auth Context - provides authentication state throughout the app
 */
const AuthContext = createContext();

/**
 * useAuth Hook - access authentication context
 * @returns {object} Auth context { user, isAuthenticated, loading, login, logout }
 */
function useAuth() {
  return useContext(AuthContext);
}

/**
 * Auth Provider Component
 * Wraps app and provides authentication state
 */
function AuthProvider({ children }) {
  const [user, setUser] = useState(null);
  const [isAuthenticated, setIsAuthenticated] = useState(false);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    // Wait for config to be loaded before initializing auth with timeout
    const initializeWhenConfigReady = async () => {
      try {
        // Use timeout-protected wait instead of infinite loop
        await delayedWait(() => !!window.config, 10000);
        await initializeAuth();
      } catch (error) {
        console.error('Timeout waiting for config:', error);
        setLoading(false);
      }
    };

    initializeWhenConfigReady();
  }, []);


  const initializeAuth = async () => {
    try {
      const urlParams = new URLSearchParams(window.location.search);
      console.log('initializeAuth starting:', {
        url: window.location.href,
        hasCode: !!urlParams.get('code'),
        hasError: !!urlParams.get('error'),
        environment: window.config?.environment
      });

      // Check for either authorization code OR error from Cognito callback
      if (urlParams.get('code') || urlParams.get('error')) {
        console.log('Found authorization code or error, calling handleCallback...');
        const success = await authService.handleCallback();
        console.log('handleCallback result:', success);
        // If handleCallback returned false due to error, it will have shown alert and redirected
        // So we can return here since the page is redirecting
        if (!success && urlParams.get('error')) {
          return; // Page is redirecting, don't continue
        }
      }

      console.log('Checking authentication status...');
      if (authService.isAuthenticated()) {
        const userInfo = authService.getUserInfo();
        console.log('User authenticated successfully:', { email: userInfo?.email });
        setUser(userInfo);
        setIsAuthenticated(true);

        // Start session monitor once authenticated
        if (window.config) {
          startSessionMonitor(authService);
        }
      } else {
        console.log('User not authenticated, will redirect to landing page');
      }
    } catch (error) {
      console.error('Auth initialization error:', error);
      alert('Authentication failed: ' + error.message);
      SecureTokenStorage.clearAllTokens();
    } finally {
      setLoading(false);
    }
  };

  const value = {
    user,
    isAuthenticated,
    loading,
    login: authService.login,
    logout: authService.logout
  };

  return React.createElement(AuthContext.Provider, { value }, children);
}

// ============ EXPORTS ============

// Expose to window for other components
window.AuthService = AuthService;
window.authService = authService;
window.AuthContext = AuthContext;
window.useAuth = useAuth;
window.AuthProvider = AuthProvider;
window.SecureTokenStorage = SecureTokenStorage;
window.SessionExpiredEvent = SessionExpiredEvent;
window.startSessionMonitor = startSessionMonitor;
window.stopSessionMonitor = stopSessionMonitor;
window.fetchWithTimeout = fetchWithTimeout;
