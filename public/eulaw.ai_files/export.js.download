/**
 * Export Utilities
 * Functions for exporting content to Word documents
 */

/**
 * Helper function to parse inline markdown formatting for docx
 * @param {string} text - Text with markdown formatting
 * @returns {Array} - Array of docx TextRun objects
 */
function parseInlineFormattingForDocx(text) {
  const runs = [];
  let remaining = text;

  // Remove citation markers like [1], [2] etc.
  remaining = remaining.replace(/\[(\d+)\]/g, '[$1]');

  // Process bold
  remaining = remaining.replace(/\*\*(.+?)\*\*/g, (match, content) => {
    return `{{BOLD}}${content}{{/BOLD}}`;
  });

  // Process italic
  remaining = remaining.replace(/\*(.+?)\*/g, (match, content) => {
    return `{{ITALIC}}${content}{{/ITALIC}}`;
  });

  // Process inline code
  remaining = remaining.replace(/`(.+?)`/g, (match, content) => {
    return `{{CODE}}${content}{{/CODE}}`;
  });

  // Parse the tagged text
  const parts = remaining.split(/(\{\{(?:BOLD|ITALIC|CODE|\/BOLD|\/ITALIC|\/CODE)\}\})/);

  let currentBold = false;
  let currentItalic = false;
  let currentCode = false;

  for (const part of parts) {
    switch (part) {
      case '{{BOLD}}':
        currentBold = true;
        continue;
      case '{{/BOLD}}':
        currentBold = false;
        continue;
      case '{{ITALIC}}':
        currentItalic = true;
        continue;
      case '{{/ITALIC}}':
        currentItalic = false;
        continue;
      case '{{CODE}}':
        currentCode = true;
        continue;
      case '{{/CODE}}':
        currentCode = false;
        continue;
    }

    if (part) {
      const runOptions = { text: part, size: 22 };
      if (currentBold) runOptions.bold = true;
      if (currentItalic) runOptions.italics = true;
      if (currentCode) {
        runOptions.font = 'Courier New';
        runOptions.size = 20;
      }
      runs.push(new window.docx.TextRun(runOptions));
    }
  }

  // If no runs were created, add the original text
  if (runs.length === 0) {
    runs.push(new window.docx.TextRun({ text: text, size: 22 }));
  }

  return runs;
}

window.parseInlineFormattingForDocx = parseInlineFormattingForDocx;

/**
 * Export AI response to Word document with sources
 * Uses docx library to create a properly formatted .docx file
 * @param {string} markdownText - The AI response in markdown format
 * @param {Array} sources - Array of source objects with URLs
 * @param {string} userQuestion - The original user question (optional)
 * @returns {Promise<boolean>} - Success status
 */
async function exportToWord(markdownText, sources = [], userQuestion = '') {
  try {
    const blob = await generateDocxBlob(markdownText, sources, userQuestion);
    const now = new Date();
    const filename = `eulaw-analysis-${now.toISOString().slice(0, 10)}.docx`;
    window.saveAs(blob, filename);
    return true;
  } catch (error) {
    console.error('Error exporting to Word:', error);
    alert('Failed to export to Word. Please try again.');
    return false;
  }
}

window.exportToWord = exportToWord;

/**
 * Generate a Word document blob without downloading
 * Used for saving AI responses to document library
 * @param {string} markdownText - The AI response in markdown format
 * @param {Array} sources - Array of source objects with URLs
 * @param {string} userQuestion - The original user question (optional)
 * @returns {Promise<Blob>} - Word document as blob
 */
async function generateDocxBlob(markdownText, sources = [], userQuestion = '') {
  const { Document, Packer, Paragraph, TextRun, HeadingLevel, ExternalHyperlink, BorderStyle } = window.docx;

  // Parse markdown to structured content
  const lines = markdownText.split('\n');
  const children = [];

  // Add header with date
  const now = new Date();
  const dateStr = now.toLocaleDateString('en-GB', {
    day: '2-digit',
    month: 'long',
    year: 'numeric'
  });

  children.push(
    new Paragraph({
      children: [
        new TextRun({ text: 'eulaw.ai Legal Analysis', bold: true, size: 32 }),
      ],
      spacing: { after: 100 }
    }),
    new Paragraph({
      children: [
        new TextRun({ text: `Generated: ${dateStr}`, italics: true, color: '666666', size: 20 }),
      ],
      spacing: { after: 300 }
    })
  );

  // Add user question if provided
  if (userQuestion) {
    children.push(
      new Paragraph({
        children: [
          new TextRun({ text: 'Question:', bold: true, size: 24 }),
        ],
        spacing: { before: 200 }
      }),
      new Paragraph({
        children: [
          new TextRun({ text: userQuestion, size: 22 }),
        ],
        spacing: { after: 300 },
        border: {
          bottom: { style: BorderStyle.SINGLE, size: 6, color: 'CCCCCC' }
        }
      })
    );
  }

  // Add response heading
  children.push(
    new Paragraph({
      children: [
        new TextRun({ text: 'Response:', bold: true, size: 24 }),
      ],
      spacing: { before: 200, after: 200 }
    })
  );

  // Process markdown lines
  let inCodeBlock = false;

  for (const line of lines) {
    const trimmedLine = line.trim();

    if (!trimmedLine) {
      children.push(new Paragraph({ spacing: { after: 100 } }));
      continue;
    }

    if (trimmedLine.startsWith('```')) {
      inCodeBlock = !inCodeBlock;
      continue;
    }

    if (inCodeBlock) {
      children.push(
        new Paragraph({
          children: [new TextRun({ text: line, font: 'Courier New', size: 20 })],
          shading: { fill: 'F5F5F5' }
        })
      );
      continue;
    }

    if (trimmedLine.startsWith('## ')) {
      children.push(
        new Paragraph({
          text: trimmedLine.replace('## ', ''),
          heading: HeadingLevel.HEADING_2,
          spacing: { before: 300, after: 150 }
        })
      );
      continue;
    }

    if (trimmedLine.startsWith('### ')) {
      children.push(
        new Paragraph({
          text: trimmedLine.replace('### ', ''),
          heading: HeadingLevel.HEADING_3,
          spacing: { before: 250, after: 100 }
        })
      );
      continue;
    }

    if (trimmedLine.startsWith('>')) {
      const quoteText = trimmedLine.replace(/^>\s*/, '');
      children.push(
        new Paragraph({
          children: [new TextRun({ text: quoteText, italics: true })],
          indent: { left: 720 },
          border: {
            left: { style: BorderStyle.SINGLE, size: 12, color: '667eea' }
          },
          spacing: { after: 100 }
        })
      );
      continue;
    }

    if (trimmedLine.startsWith('- ') || trimmedLine.startsWith('* ')) {
      const bulletText = trimmedLine.replace(/^[-*]\s*/, '');
      children.push(
        new Paragraph({
          children: window.parseInlineFormattingForDocx(bulletText),
          bullet: { level: 0 },
          spacing: { after: 50 }
        })
      );
      continue;
    }

    if (/^\d+\.\s/.test(trimmedLine)) {
      const listText = trimmedLine.replace(/^\d+\.\s*/, '');
      children.push(
        new Paragraph({
          children: window.parseInlineFormattingForDocx(listText),
          numbering: { reference: 'default-numbering', level: 0 },
          spacing: { after: 50 }
        })
      );
      continue;
    }

    children.push(
      new Paragraph({
        children: window.parseInlineFormattingForDocx(trimmedLine),
        spacing: { after: 150 }
      })
    );
  }

  // Add sources section if available
  const sourcesWithUrls = sources.filter(s => s.source_url);
  if (sourcesWithUrls.length > 0) {
    children.push(
      new Paragraph({ spacing: { before: 400 } }),
      new Paragraph({
        children: [
          new TextRun({ text: 'Sources', bold: true, size: 28 }),
        ],
        border: {
          top: { style: BorderStyle.SINGLE, size: 6, color: 'CCCCCC' }
        },
        spacing: { before: 300, after: 200 }
      })
    );

    sourcesWithUrls.forEach((source, idx) => {
      const title = source.title || source.journal_number || source.filename || `Source ${idx + 1}`;
      children.push(
        new Paragraph({
          children: [
            new TextRun({ text: `[${idx + 1}] `, bold: true }),
            new ExternalHyperlink({
              children: [
                new TextRun({ text: title, color: '667eea', underline: {} })
              ],
              link: source.source_url
            })
          ],
          spacing: { after: 100 }
        })
      );

      children.push(
        new Paragraph({
          children: [
            new TextRun({ text: source.source_url, color: '999999', size: 18 })
          ],
          indent: { left: 360 },
          spacing: { after: 150 }
        })
      );
    });
  }

  // Add footer
  children.push(
    new Paragraph({ spacing: { before: 400 } }),
    new Paragraph({
      children: [
        new TextRun({
          text: 'This document was generated by eulaw.ai. For legal advice, please consult a qualified legal professional.',
          italics: true,
          color: '999999',
          size: 18
        })
      ],
      border: {
        top: { style: BorderStyle.SINGLE, size: 6, color: 'EEEEEE' }
      },
      spacing: { before: 200 }
    })
  );

  // Create document
  const doc = new Document({
    numbering: {
      config: [{
        reference: 'default-numbering',
        levels: [{
          level: 0,
          format: 'decimal',
          text: '%1.',
          alignment: 'start',
          style: { paragraph: { indent: { left: 720, hanging: 360 } } }
        }]
      }]
    },
    sections: [{
      properties: {
        page: {
          margin: { top: 1440, right: 1440, bottom: 1440, left: 1440 }
        }
      },
      children: children
    }]
  });

  // Return blob without saving
  return await Packer.toBlob(doc);
}

window.generateDocxBlob = generateDocxBlob;

/**
 * Generate markdown content for saving AI responses
 * @param {string} markdownText - The AI response in markdown format
 * @param {Array} sources - Array of source objects with URLs
 * @param {string} userQuestion - The original user question (optional)
 * @returns {string} - Formatted markdown content
 */
function generateMarkdownContent(markdownText, sources = [], userQuestion = '') {
  const now = new Date();
  const dateStr = now.toLocaleDateString('en-GB', {
    day: '2-digit',
    month: 'long',
    year: 'numeric'
  });

  let content = `# eulaw.ai Legal Analysis\n\n`;
  content += `*Generated: ${dateStr}*\n\n`;

  if (userQuestion) {
    content += `## Question\n\n${userQuestion}\n\n`;
    content += `---\n\n`;
  }

  content += `## Response\n\n${markdownText}\n\n`;

  // Add sources section if available
  const sourcesWithUrls = sources.filter(s => s.source_url);
  if (sourcesWithUrls.length > 0) {
    content += `---\n\n## Sources\n\n`;
    sourcesWithUrls.forEach((source, idx) => {
      const title = source.title || source.journal_number || source.filename || `Source ${idx + 1}`;
      content += `[${idx + 1}] [${title}](${source.source_url})\n`;
      content += `   ${source.source_url}\n\n`;
    });
  }

  content += `---\n\n`;
  content += `*This document was generated by eulaw.ai. For legal advice, please consult a qualified legal professional.*\n`;

  return content;
}

window.generateMarkdownContent = generateMarkdownContent;

/**
 * Format time for display
 * @param {string|Date} timestamp - Timestamp to format
 * @returns {string} - Formatted time string (DD.MM.YYYY - HH:MM)
 */
function formatTime(timestamp) {
  if (!timestamp) return '';
  const date = new Date(timestamp);
  const day = String(date.getDate()).padStart(2, '0');
  const month = String(date.getMonth() + 1).padStart(2, '0');
  const year = date.getFullYear();
  const hours = String(date.getHours()).padStart(2, '0');
  const minutes = String(date.getMinutes()).padStart(2, '0');
  return `${day}.${month}.${year} - ${hours}:${minutes}`;
}

window.formatTime = formatTime;
