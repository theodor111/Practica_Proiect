  // ============ CHAT FOLDER METHODS ============

  /**
   * Get chat folder contents (folders + sessions) for a given folder
   * @param {string} folderId - Folder ID ('root' for root level)
   * @param {number} limit - Max items to return
   * @returns {Promise<object>} { folder, items, nextToken }
   */
  async getChatFolderContents(folderId = 'root', limit = 500) {
    try {
      const response = await fetchWithRetry(`/api/chat/folders/${folderId}?limit=${limit}`, {
        method: 'GET',
        headers: this.getAuthHeaders()
      }, {
        maxRetries: 3,
        timeoutMs: 30000,
        baseDelay: 500
      });

      await this._checkResponse(response, 'Failed to fetch chat folder contents');
      const data = await response.json();
      // Normalize item IDs: chat API returns folderId/sessionId, not a unified itemId
      data.items = (data.items || []).map(item => ({
        ...item,
        id: item.folderId || item.sessionId
      }));
      return data;
    } catch (error) {
      console.error('getChatFolderContents error:', error);
      throw error;
    }
  }

