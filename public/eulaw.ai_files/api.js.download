  /**
   * Move a chat session to a new folder
   * @param {string} sessionId - Session ID
   * @param {string} parentId - New parent folder ID
   * @returns {Promise<object>} Updated session
   */
  async moveChatSession(sessionId, parentId) {
    try {
      const response = await fetchWithRetry(`/api/chat/session/${sessionId}/move`, {
        method: 'PUT',
        headers: this.getAuthHeaders(),
        body: JSON.stringify({ parentFolderId: parentId })
      }, {
        maxRetries: 2,
        timeoutMs: 15000,
        baseDelay: 500
      });

      await this._checkResponse(response, 'Failed to move chat session');
      return await response.json();
    } catch (error) {
      console.error('moveChatSession error:', error);
      throw error;
    }
  }

  /**
   * Get document counts per jurisdiction from OpenSearch
   * Public endpoint — no auth required, CDN-cached for 24h
   * @returns {Promise<Object>} e.g. { EU: 385235, DK: 396340, INTL: 4421 }
   */
  async getDocumentCounts() {
    try {
      const response = await fetchWithRetry('/api/serviceinfo/document-counts', {
        method: 'GET',
      }, {
        maxRetries: 1,
        timeoutMs: 15000,
        baseDelay: 500
      });

      await this._checkResponse(response, 'Failed to fetch document counts');
      return await response.json();
    } catch (error) {
      console.error('getDocumentCounts error:', error);
      return null;
    }
  }
}

// Create singleton instance
const apiService = new ApiService();

// ============ EXPORTS ============

// Expose to window for other components
window.ApiService = ApiService;
window.apiService = apiService;
window.fetchWithRetry = fetchWithRetry;
