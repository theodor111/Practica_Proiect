  }

  /**
   * Delete a folder from the document library
   * @param {string} itemId - Folder item ID
   * @param {boolean} recursive - Whether to delete contents recursively
   * @returns {Promise<object>} Deletion result with counts
   */
  async deleteFolder(itemId, recursive = true) {
    try {
      // Recursive delete can be slow for large folder trees; longer timeout, fewer retries
      const response = await fetchWithRetry(`/api/library/folders/${itemId}?recursive=${recursive}`, {
        method: 'DELETE',
        headers: this.getAuthHeaders()
      }, {
        maxRetries: 1,
        timeoutMs: 60000,
        baseDelay: 1000
      });

      await this._checkResponse(response, 'Failed to delete folder');

      const result = await response.json();
      return result.data;
    } catch (error) {
      console.error('deleteFolder error:', error);
      throw error;
    }
  }

  /**
