/**
 * API Service
 * Handles all API calls to the backend (chat, documents, subscriptions)
 * Requires: auth.js to be loaded first (for SecureTokenStorage, SessionExpiredEvent, fetchWithTimeout)
 */

// ============ RETRY UTILITY ============

/**
 * Fetch with exponential backoff retry
 * @param {string} url - URL to fetch
 * @param {object} options - Fetch options
 * @param {object} retryConfig - Retry configuration
 * @returns {Promise<Response>}
 */
async function fetchWithRetry(url, options = {}, retryConfig = {}) {
  const {
    maxRetries = 3,
    baseDelay = 1000,
    timeoutMs = 30000,
    backoffMultiplier = 2,
    maxDelay = 32000
  } = retryConfig;

  let lastError;

  for (let attempt = 0; attempt <= maxRetries; attempt++) {
    try {
      // Use fetchWithTimeout from auth.js (exposed on window)
      if (!window.fetchWithTimeout) {
        throw new Error('fetchWithTimeout not available - ensure auth.js is loaded first');
      }
      return await window.fetchWithTimeout(url, options, timeoutMs);
    } catch (error) {
      lastError = error;

      // Don't retry if the request was intentionally aborted
      if (error.name === 'AbortError') throw error;

      if (attempt < maxRetries) {
        const delay = Math.min(baseDelay * Math.pow(backoffMultiplier, attempt), maxDelay);
        console.log(`Retry attempt ${attempt + 1}/${maxRetries} after ${delay}ms:`, error.message);
        await new Promise(resolve => setTimeout(resolve, delay));
      }
    }
  }

  throw lastError;
}

// ============ API SERVICE ============

/**
 * API Service Class
 * Handles all backend API interactions
 */
class ApiService {
  /**
   * Check response status and handle 401 session expiration
   * @param {Response} response - Fetch response
   * @param {string} errorMessage - Error message for non-401 failures
   */
  async _checkResponse(response, fallbackMessage) {
    if (!response.ok) {
      if (response.status === 401) {
        if (window.SessionExpiredEvent) {
          window.dispatchEvent(new window.SessionExpiredEvent());
        }
        throw new Error('Session expired - please log in again');
      }
      // Try to extract specific error message from response body
      let message = fallbackMessage;
      try {
        const body = await response.json();
        const raw = body.error || body.message;
        if (typeof raw === 'string') {
          message = raw;
        } else if (raw && typeof raw === 'object') {
          message = raw.message || raw.detail || JSON.stringify(raw);
        }
      } catch (_) {
        // Response body not JSON, use fallback
      }
      throw new Error(message);
    }
  }

  /**
   * Get authentication headers for API requests
   * @returns {object} Headers with authorization token
   */
  getAuthHeaders() {
    if (!window.SecureTokenStorage) {
      throw new Error('SecureTokenStorage not available - ensure auth.js is loaded first');
    }
    const idToken = window.SecureTokenStorage.getToken('idToken');
    return {
      'Authorization': 'Bearer ' + idToken,
      'Content-Type': 'application/json'
    };
  }

  /**
   * Send a chat message to the AI
   * @param {string} message - User message
   * @param {string|null} sessionId - Session ID (null for new session)
   * @param {Array} files - Attached files (each must have itemId from Document Library)
   * @param {object|null} filters - Jurisdiction, year, and other filters
   * @returns {Promise<Response>} Streaming response
   */
  async sendMessage(message, sessionId = null, files = [], filters = null, { signal } = {}) {
    // Normalize files to array for backward compatibility
    const filesArray = Array.isArray(files) ? files : (files ? [files] : []);
    console.log('ApiService.sendMessage called:', { message, sessionId, fileCount: filesArray.length, filters });

    const requestBody = {
      inputText: message.trim(),
      sessionId: sessionId,
      temperature: 0.7,
      maxTokens: 4096
    };

    // Add filters if present (jurisdiction, documentFamily, yearRange, caseLaw)
    if (filters && (filters.jurisdiction?.length > 0 || filters.documentFamily?.length > 0 || filters.yearRange || filters.caseLaw)) {
      requestBody.filters = filters;
      console.log('Adding filters to request:', filters);
    }

    // Add document references if present (itemId only — all files must already be in Document Library)
    if (filesArray.length > 0) {
      requestBody.documents = filesArray.map(file => ({ itemId: file.itemId }));
    }

    console.log('Request body:', { ...requestBody, documents: requestBody.documents ? `${requestBody.documents.length} documents` : 'none' });
    console.log('Endpoint:', '/chat');

    const headers = this.getAuthHeaders();
    console.log('Auth headers:', headers);

    // No retries — chat POST is not idempotent (creates session, counts usage)
    try {
      const response = await fetchWithRetry('/api/chat', {
        method: 'POST',
        headers: headers,
        body: JSON.stringify(requestBody),
        signal: signal
      }, {
        maxRetries: 0,
        timeoutMs: 120000 // Streaming can take longer
      });

      console.log('Response status:', response.status);
      console.log('Response headers:', Object.fromEntries(response.headers.entries()));

      await this._checkResponse(response, 'Chat request failed');

      console.log('API call successful, returning response');
      return response;
    } catch (error) {
      console.error('sendMessage error:', error);
      throw error;
    }
  }

  async translatePassage(text, targetLanguage) {
    const response = await fetchWithRetry('/api/chat', {
      method: 'POST',
      headers: this.getAuthHeaders(),
      body: JSON.stringify({ action: 'translatePassage', text, targetLanguage })
    }, { maxRetries: 1, timeoutMs: 20000 });

    await this._checkResponse(response, 'translatePassage failed');
    const data = await response.json();
    if (data.error) throw new Error(data.error);
    return data;
  }

  /**
   * Convert file to base64 string
   * @param {File} file - File object
   * @returns {Promise<string>} Base64 encoded file data
   */
  async fileToBase64(file) {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();

      // Add timeout for file reading
      const readTimeout = setTimeout(() => {
        reader.abort();
        reject(new Error('File reading timeout'));
      }, 30000); // 30 second timeout

      reader.readAsDataURL(file);
      reader.onload = () => {
        clearTimeout(readTimeout);
        const base64 = reader.result.split(',')[1]; // Remove data:mime;base64, prefix
        resolve(base64);
      };
      reader.onerror = (error) => {
        clearTimeout(readTimeout);
        reject(error);
      };
    });
  }

  /**
   * Get MIME type from file extension
   * @param {string} extension - File extension
   * @returns {string} MIME type
   */
  getMimeType(extension) {
    const mimeMap = {
      'pdf': 'application/pdf',
      'doc': 'application/msword',
      'docx': 'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
      'txt': 'text/plain',
      'html': 'text/html',
      'md': 'text/markdown',
      'rtf': 'application/rtf'
    };
    return mimeMap[extension] || 'application/octet-stream';
  }

  /**
   * Get chat history for current user
   * @returns {Promise<Array>} List of chat sessions
   */
  async getChatHistory() {
    try {
      const response = await fetchWithRetry('/api/chat/session', {
        method: 'GET',
        headers: this.getAuthHeaders()
      }, {
        maxRetries: 3,
        timeoutMs: 30000,
        baseDelay: 500
      });

      await this._checkResponse(response, 'Failed to fetch history');
      return await response.json();
    } catch (error) {
      console.error('getChatHistory error:', error);
      throw error;
    }
  }

