  /**
   * Save AI response to document library as .md
   * @param {string} markdownText - AI response in markdown
   * @param {Array} citations - Source citations
   * @param {string} userQuestion - Original user question
   * @param {number} responseNumber - Response number in conversation
   * @returns {Promise<object>} Saved document info
   */
  async saveAIResponseToLibrary(markdownText, citations = [], userQuestion = '', responseNumber = 1) {
    try {
      // Generate markdown content
      let markdownContent;
      if (window.generateMarkdownContent) {
        markdownContent = window.generateMarkdownContent(markdownText, citations, userQuestion);
      } else {
        // Fallback: simple markdown with header and response
        console.log('generateMarkdownContent not available, using fallback');
        const now = new Date();
        const dateStr = now.toLocaleDateString('en-GB', {
          day: '2-digit',
          month: 'long',
          year: 'numeric'
        });
        markdownContent = `# eulaw.ai Legal Analysis\n\n*Generated: ${dateStr}*\n\n`;
        if (userQuestion) {
          markdownContent += `## Question\n\n${userQuestion}\n\n---\n\n`;
        }
        markdownContent += `## Response\n\n${markdownText}\n\n`;
        markdownContent += `---\n\n*This document was generated by eulaw.ai.*\n`;
      }

      // Convert markdown string to base64
      const base64Data = btoa(unescape(encodeURIComponent(markdownContent)));

      // Generate filename
      const now = new Date();
      const timestamp = now.toISOString().replace(/[:.]/g, '-').split('T').join('_').slice(0, -5);
      const questionPreview = userQuestion
        ? userQuestion.replace(/[^a-zA-Z0-9\s]/g, '').trim().split(/\s+/).slice(0, 5).join('_')
        : 'AI_Response';
      const filename = `${questionPreview}_${timestamp}_R${responseNumber}.md`;

      // Send to Document Library API (no retries — POST is not idempotent)
      const response = await fetchWithRetry('/api/library/files', {
        method: 'POST',
        headers: this.getAuthHeaders(),
        body: JSON.stringify({
          name: filename,
          data: base64Data,
          mimeType: 'text/markdown'
        })
      }, {
        maxRetries: 0,
        timeoutMs: 30000
      });

      await this._checkResponse(response, 'Failed to save document to library');

      const result = await response.json();
      return result.data;
    } catch (error) {
      console.error('saveAIResponseToLibrary error:', error);
      throw error;
    }
  }

  /**
   * Save a generated document artifact to the document library.
   * Uploads the raw Markdown as `{sanitized title}.md` with no template wrapping —
   * artifacts are already structured documents.
   * @param {string} title - Artifact title (becomes filename)
   * @param {string} content - Raw Markdown content
   * @param {string} [documentType] - Unused for now; reserved for future tagging
   * @returns {Promise<object>} Saved document info
   */
  async saveArtifactToLibrary(title, content, documentType) {
    if (!title || !content) {
      throw new Error('title and content are required');
    }

    // Sanitize title into a filename. Unicode-aware per .claude/rules/unicode-validation.md —
    // keeps European characters (æ, ø, ü, é) and digits; strips punctuation/path separators.
    const cleaned = title
      .replace(/[^\p{L}\p{N}_ \-()]+/gu, ' ')
      .replace(/\s+/g, ' ')
      .trim()
      .slice(0, 200);
    const filename = (cleaned || 'Generated_Document') + '.md';

    const base64Data = btoa(unescape(encodeURIComponent(content)));

    const response = await fetchWithRetry('/api/library/files', {
      method: 'POST',
      headers: this.getAuthHeaders(),
      body: JSON.stringify({
        name: filename,
        data: base64Data,
        mimeType: 'text/markdown'
      })
    }, {
      maxRetries: 0,
      timeoutMs: 30000
    });

    await this._checkResponse(response, 'Failed to save artifact to library');

    const result = await response.json();
    return result.data;
  }

  /**
   * Upload a file directly to the document library
   * @param {File} file - File object to upload
   * @param {string|null} parentId - Target folder ID (null for root)
   * @returns {Promise<object>} Saved document info
   */
  async uploadFileToLibrary(file, parentId = null) {
    try {
      // Convert file to base64
      const base64Data = await this.fileToBase64(file);

      // Determine MIME type from file object or extension
      const extension = file.name.split('.').pop().toLowerCase();
      const mimeType = file.type || this.getMimeType(extension);

      const body = {
        name: file.name,
        data: base64Data,
        mimeType: mimeType
      };
      if (parentId) {
        body.parentId = parentId;
      }

      // Send to Document Library API (no retries — POST is not idempotent)
      const response = await fetchWithRetry('/api/library/files', {
        method: 'POST',
        headers: this.getAuthHeaders(),
        body: JSON.stringify(body)
      }, {
        maxRetries: 0,
        timeoutMs: 30000
      });

      await this._checkResponse(response, 'Failed to upload document to library');

      const result = await response.json();
      return result.data;
    } catch (error) {
      console.error('uploadFileToLibrary error:', error);
      throw error;
    }
  }

