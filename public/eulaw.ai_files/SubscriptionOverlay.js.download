/**
 * Subscription Overlay Component
 * Displays subscription paywall with plan details and checkout button
 */

// React hooks accessed via React.useState, React.useEffect, etc.

// Subscription Overlay Component - Minimalist Design
const SubscriptionOverlay = ({ onClose, onLicenseClick, onPrivacyClick, agreementAccepted, onAgreementChange, onSubscribe, isLoading }) => {
  React.useEffect(() => {
    const handleKeyDown = (e) => { if (e.key === 'Escape') onClose(); };
    document.addEventListener('keydown', handleKeyDown);
    return () => document.removeEventListener('keydown', handleKeyDown);
  }, [onClose]);

  return React.createElement('div', {
    className: 'subscription-overlay subscription-required modal-overlay modal-overlay-heavy',
    onClick: (e) => { if (e.target === e.currentTarget) onClose(); }
  },
    React.createElement('div', {
      className: 'subscription-dialog modal-dialog modal-dialog-subscription',
      style: { position: 'relative' }
    },
      // Close button
      React.createElement('button', {
        className: 'subscription-close-btn',
        onClick: onClose,
        'aria-label': 'Close'
      }, '\u00D7'),

      // Header
      React.createElement('div', {
        className: 'subscription-header'
      },
        React.createElement('h2', {
          className: 'subscription-plan-title'
        }, 'Full Access'),
        React.createElement('p', {
          className: 'subscription-subtitle'
        }, 'Cancel anytime')
      ),

      // Price Section
      React.createElement('div', {
        className: 'subscription-price-section'
      },
        React.createElement('div', {
          className: 'subscription-price'
        }, '€39', React.createElement('span', {
          className: 'subscription-period subscription-period-label'
        }, '/month'))
      ),

      // Features
      React.createElement('div', {
        className: 'subscription-features'
      },
        [
          'Unlimited legal queries',
          'All data sources included',
          'Document upload & analysis',
          '24 EU languages',
          'Conversation history',
          'Priority support'
        ].map((feature, index) =>
          React.createElement('div', {
            key: index,
            className: 'subscription-feature-item'
          },
            React.createElement('div', {
              className: 'subscription-feature-bullet'
            }),
            feature
          )
        )
      ),

      // Agreement Checkbox
      React.createElement('div', {
        className: 'subscription-agreement-container'
      },
        React.createElement('input', {
          type: 'checkbox',
          id: 'agreement-checkbox',
          checked: agreementAccepted,
          onChange: (e) => onAgreementChange(e.target.checked),
          className: 'subscription-checkbox-input'
        }),
        React.createElement('label', {
          htmlFor: 'agreement-checkbox',
          className: 'subscription-agreement-label'
        },
          'I accept the ',
          React.createElement('a', {
            href: '#',
            onClick: (e) => { e.preventDefault(); onLicenseClick(); },
            className: 'subscription-agreement-link'
          }, 'User License Agreement'),
          ' and ',
          React.createElement('a', {
            href: '#',
            onClick: (e) => { e.preventDefault(); onPrivacyClick(); },
            className: 'subscription-agreement-link'
          }, 'Privacy Policy'),
          ', and understand that eulaw.ai provides legal information only, not legal advice.'
        )
      ),

      // Subscribe Button
      React.createElement('button', {
        className: `subscription-subscribe-btn${isLoading ? ' loading' : agreementAccepted ? ' enabled' : ' disabled'}`,
        onClick: onSubscribe,
        disabled: !agreementAccepted || isLoading
      },
        isLoading
          ? React.createElement('i', {
              className: 'fas fa-spinner fa-spin'
            })
          : React.createElement('i', { className: 'fas fa-lock' }),
        isLoading ? 'Processing...' : 'Checkout'
      ),

      // Footer
      React.createElement('p', {
        className: 'subscription-footer'
      }, 'Cancel anytime \u2022 Add VAT after checkout')
    )
  );
};

// Export to window
window.SubscriptionOverlay = SubscriptionOverlay;
